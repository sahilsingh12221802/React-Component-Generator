{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "type": "dashboard"
      }
    ]
  },
  "panels": [
    {
      "type": "gauge",
      "title": "CPU Usage %",
      "datasource": "Prometheus",
      "targets": [
        { "expr": "system_cpu_usage_percent", "refId": "A" }
      ],
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 0 }
    },
    {
      "type": "gauge",
      "title": "Memory Used (MB)",
      "datasource": "Prometheus",
      "targets": [
        { "expr": "system_memory_usage_bytes / 1024 / 1024", "refId": "A" }
      ],
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 0 }
    },
    {
      "type": "gauge",
      "title": "Memory Total (MB)",
      "datasource": "Prometheus",
      "targets": [
        { "expr": "system_memory_total_bytes / 1024 / 1024", "refId": "A" }
      ],
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 }
    },
    {
      "type": "stat",
      "title": "System Status",
      "datasource": "Prometheus",
      "targets": [
        { "expr": "up", "refId": "A" }
      ],
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 }
    },

    {
      "type": "stat",
      "title": "Total API Requests",
      "datasource": "Prometheus",
      "targets": [
        { "expr": "api_requests_total", "refId": "A" }
      ],
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 8 }
    },
    {
      "type": "stat",
      "title": "Generated Components",
      "datasource": "Prometheus",
      "targets": [
        { "expr": "generated_components_total", "refId": "A" }
      ],
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 8 }
    },
    {
      "type": "stat",
      "title": "Gemini API Calls",
      "datasource": "Prometheus",
      "targets": [
        { "expr": "gemini_api_calls_total", "refId": "A" }
      ],
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 8 }
    },
    {
      "type": "stat",
      "title": "Errors",
      "datasource": "Prometheus",
      "targets": [
        { "expr": "api_requests_total{status=~\"5..\"}", "refId": "A" }
      ],
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 8 }
    },

    {
      "type": "timeseries",
      "title": "API Request Rate",
      "datasource": "Prometheus",
      "targets": [
        { "expr": "rate(api_requests_total[1m])", "refId": "A" }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 }
    },
    {
      "type": "timeseries",
      "title": "API Duration",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(api_request_duration_seconds_sum[1m]) / rate(api_request_duration_seconds_count[1m])",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 }
    },
    {
      "type": "timeseries",
      "title": "Gemini Calls Rate",
      "datasource": "Prometheus",
      "targets": [
        { "expr": "rate(gemini_api_calls_total[1m])", "refId": "A" }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 22 }
    },
    {
      "type": "timeseries",
      "title": "Error Rate",
      "datasource": "Prometheus",
      "targets": [
        { "expr": "rate(api_requests_total{status=~\"5..\"}[1m])", "refId": "A" }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 22 }
    }
  ],
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "title": "React Component Generator Monitoring",
  "schemaVersion": 27,
  "version": 1
}